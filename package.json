{
  "name": "the-ballpark",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client-angular && npm run dev",
    "install:all": "npm install && cd server && npm install && cd ../client-angular && npm install",
    "db:migrate": "cd server && node src/db/migrate.js",
    "db:seed": "cd server && node src/db/seed.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
